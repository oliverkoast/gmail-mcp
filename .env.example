# Copy to .env and fill in. Never commit .env (it's git-ignored).
#
# GMAIL_ACCOUNTS is the list of account ids. For each id there must be a
# GMAIL_<ID>_EMAIL and GMAIL_<ID>_APP_PASSWORD (id uppercased).
# To add a 4th account: append its id here and add its two vars. That's it.
#
# App passwords: https://myaccount.google.com/apppasswords (requires 2-Step
# Verification). Paste the 16-character password with or without spaces.

GMAIL_ACCOUNTS=arcforma,formai,personal

GMAIL_ARCFORMA_EMAIL=oliver@arcforma.ai
GMAIL_ARCFORMA_APP_PASSWORD=

GMAIL_FORMAI_EMAIL=oliver@formai.build
GMAIL_FORMAI_APP_PASSWORD=

GMAIL_PERSONAL_EMAIL=oliver.korzen@gmail.com
GMAIL_PERSONAL_APP_PASSWORD=
