# Copy to .env and fill in. Never commit .env (it's git-ignored).
#
# MAIL_ACCOUNTS is the list of account ids. Per id:
#   MAIL_<ID>_EMAIL        (always)
#   MAIL_<ID>_PROVIDER     gmail (default) | gmail-api | outlook
#   MAIL_<ID>_APP_PASSWORD (provider "gmail" only)
#
# Providers:
#   gmail      Gmail over IMAP with an app password — the 5-minute path.
#              https://myaccount.google.com/apppasswords (needs 2-Step
#              Verification). Paste with or without spaces.
#   gmail-api  Gmail REST API + OAuth (gmail.readonly) — for Google orgs
#              where IT disabled IMAP/app passwords. Needs the GOOGLE_OAUTH_*
#              vars below, then: npm run auth <id>
#   outlook    Microsoft 365 / outlook.com via Microsoft Graph (Mail.Read) —
#              needs MS_CLIENT_ID below, then: npm run auth <id>
#
# To add an account: append its id and add its vars. No code changes.

MAIL_ACCOUNTS=arcforma,formai,personal

MAIL_ARCFORMA_EMAIL=oliver@arcforma.ai
MAIL_ARCFORMA_APP_PASSWORD=

MAIL_FORMAI_EMAIL=oliver@formai.build
MAIL_FORMAI_APP_PASSWORD=

MAIL_PERSONAL_EMAIL=oliver.korzen@gmail.com
MAIL_PERSONAL_APP_PASSWORD=

# Example hardened-Google-org account (uncomment + add id to MAIL_ACCOUNTS):
# MAIL_CLIENTG_PROVIDER=gmail-api
# MAIL_CLIENTG_EMAIL=user@client-google-org.com

# Example Microsoft 365 account:
# MAIL_CLIENTMS_PROVIDER=outlook
# MAIL_CLIENTMS_EMAIL=user@client-ms-org.com

# --- Shared OAuth app settings (only needed if a provider above uses them) ---

# gmail-api: a "Desktop app" OAuth client from any Google Cloud project
# (APIs & Services -> Credentials). See CLIENT-SETUP.md.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# outlook: an Entra ID app registration (public client, Mail.Read delegated).
# The Arcforma "claude-mail" registration (public, no secret — safe to ship)
# is pre-filled; it's reusable across every client engagement.
MS_CLIENT_ID=61497fc7-c9eb-48fe-a6aa-9f3a25a4da61

# MS_TENANT controls which Microsoft accounts can sign in:
#   organizations  ← RECOMMENDED for client setups: work/school accounts only.
#                    Removes the "Work or Personal?" picker entirely, which is
#                    the classic wrong-mailbox trap (a personal account with
#                    the same email reads an empty outlook.com mailbox).
#   common         (default) also allows personal @outlook.com accounts —
#                    only needed if an account genuinely is personal.
MS_TENANT=organizations
